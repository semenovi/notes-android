<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Notes.Views.Windows.MainWindow"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Notes.Views.Windows.Controls"
             xmlns:shared="clr-namespace:Notes.Views.Controls"
             Title="Notes">

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:WindowsFolderTreeView x:Name="FolderTree" Grid.Column="0"
                                             FolderSelected="OnFolderSelected" />

            <BoxView Grid.Column="1" BackgroundColor="#C6C6C8" />

            <controls:WindowsNoteListView x:Name="NotesList" Grid.Column="2"
                                           NoteSelected="OnNoteSelected"
                                           NoteDeleted="OnNoteDeleted" />

            <BoxView Grid.Column="3" BackgroundColor="#C6C6C8" />

            <controls:WindowsNoteEditor x:Name="NoteEditor" Grid.Column="4" />
        </Grid>

        <shared:ToastOverlay x:Name="Toast" />
        <shared:ProgressOverlay x:Name="Progress" />
    </Grid>

</ContentPage>
