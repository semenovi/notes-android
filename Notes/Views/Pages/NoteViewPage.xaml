<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Notes.Helpers"
             xmlns:shared="clr-namespace:Notes.Views.Controls"
             x:Class="Notes.Views.Pages.NoteViewPage"
             Shell.NavBarIsVisible="True"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit"
                     Order="Secondary"
                     Clicked="OnEditClicked" />
        <ToolbarItem Text="Delete Note"
                     Order="Secondary"
                     Clicked="OnDeleteNoteClicked" />
    </ContentPage.ToolbarItems>

    <Grid IsClippedToBounds="False">
        <!-- Current screen — opaque, slides right on swipe -->
        <Grid x:Name="RootGrid"
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
            <WebView x:Name="NoteContentWebView" />
        </Grid>

        <!-- Shadow cast from RootGrid onto the previous screen.
             Positioned to the left of RootGrid, moves with it. -->
        <ContentView x:Name="SwipeShadow"
                     WidthRequest="24"
                     HorizontalOptions="Start"
                     VerticalOptions="Fill"
                     InputTransparent="True"
                     Opacity="0">
            <ContentView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00000000" Offset="0" />
                    <GradientStop Color="#55000000" Offset="1" />
                </LinearGradientBrush>
            </ContentView.Background>
        </ContentView>

        <shared:ProgressOverlay x:Name="PageProgress" />
    </Grid>
</ContentPage>
