<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Notes.Helpers"
             xmlns:shared="clr-namespace:Notes.Views.Controls"
             x:Class="Notes.Views.Pages.FoldersPage"
             Title="Folders">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Sync: OFF"
                     x:Name="SyncToggleItem"
                     Order="Secondary"
                     Clicked="OnSyncToggleClicked" />
        <ToolbarItem Text="Sync Now"
                     Order="Secondary"
                     Clicked="OnSyncNowClicked" />
        <ToolbarItem Text="Sync Settings..."
                     Order="Secondary"
                     Clicked="OnSyncSettingsClicked" />
        <ToolbarItem Text="Export Backup"
                     Order="Secondary"
                     Clicked="OnExportBackupClicked" />
        <ToolbarItem Text="Import Backup"
                     Order="Secondary"
                     Clicked="OnImportBackupClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <CollectionView x:Name="FoldersCollection" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="15" ColumnDefinitions="Auto,*">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFolderTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="{Binding Icon}"
                               Style="{StaticResource MaterialIconLabel}"
                               FontSize="24"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding Name}"
                               FontSize="16"
                               VerticalOptions="Center"
                               Margin="10,0,0,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button x:Name="AddFolderButton"
                Text="{x:Static helpers:MaterialIconCodes.Add}"
                FontFamily="MaterialIcons"
                FontSize="24"
                CornerRadius="30"
                WidthRequest="60"
                HeightRequest="60"
                Padding="0"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0,0,20,20"
                Clicked="OnAddFolderClicked" />

        <shared:ProgressOverlay x:Name="PageProgress" />
    </Grid>
</ContentPage>